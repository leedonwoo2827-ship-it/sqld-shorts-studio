# compy-ui 환경설정 예시. 이 파일을 .env 로 복사해서 값을 바꿔 쓰세요.
# (setup.bat 이 .env 가 없으면 이 파일을 복사해 만듭니다.)

# --- ComfyUI 서버 위치 ---
# 이 PC 에서 ComfyUI 를 돌리면 기본값 그대로. GPU 노트북에서 돌리고 사무용 PC 에서
# 연결하려면 그 노트북의 IP 로 바꾸세요 (예: COMFY_HOST=192.168.0.50).
COMFY_HOST=127.0.0.1
COMFY_PORT=8188

# --- img2video(실제 움직임) 사용 여부 ---
# 1=하이브리드(가능하면 영상, 아니면 Ken Burns), 0=이미지만.
# 전용 GPU 가 없는 PC 에서는 사실상 이미지만 생성됩니다(자동 폴백).
COMFY_ENABLE_VIDEO=1

# --- 워크플로우 JSON 경로 (ComfyUI 'Save (API Format)' 로 내보낸 파일) ---
COMFY_TXT2IMG_WORKFLOW=workflows/txt2img_api.json
COMFY_IMG2VIDEO_WORKFLOW=workflows/img2video_api.json

# --- 한 씬 생성 최대 대기(초) ---
COMFY_TIMEOUT=600

# --- 해상도 긴 변 상한(px) — 저사양(CPU)에서 속도용. 0=제한없음(GPU). ---
# 이 사무용 PC(Iris Xe/CPU)는 768 권장. 비율 유지하며 8의 배수로 축소.
COMFY_MAX_DIM=768

# --- 시드 고정(정수) 하면 재현 가능. 비우면 씬 인덱스 기반 고정 시드. ---
# COMFY_SEED=12345
